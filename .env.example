# ============================================================
#  SentinelAI — Environment Variables
#  Copy this file to .env and fill in your actual values
#  NEVER commit .env to the repository
# ============================================================

# --- JWT ---
# Secret key for signing JWT tokens. Make this long and random.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRE_HOURS=24

# --- Database ---
# Path to the SQLite database file
DATABASE_URL=./sentinelai.db

# --- OTP / Email (Gmail SMTP) ---
# Use your Gmail address and an App Password (NOT your real password)
# To create an App Password: Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_gmail_address@gmail.com
SMTP_APP_PASSWORD=your_16_char_app_password
SMTP_TIMEOUT=10
SMTP_RETRIES=3
SMTP_STRICT_MODE=0  # Set to 1 in production to fail hard on SMTP errors (no console fallback)
OTP_EXPIRE_MINUTES=5

# --- Trust Score Thresholds ---
# Customize these to tune how aggressive the system is
TRUST_THRESHOLD_DIRECT_LOGIN=70   # Above this → no OTP needed
TRUST_THRESHOLD_OTP=40            # Between OTP threshold and above → OTP required
TRUST_THRESHOLD_QUARANTINE=20     # Below this → quarantine + admin alert

# --- Velocity Detection ---
# How many registrations from the same IP in one hour triggers a bot wave alert
VELOCITY_IP_LIMIT=3
# How many total registrations per minute triggers a platform-wide bot wave
VELOCITY_PLATFORM_LIMIT=10
# Minimum seconds a legitimate registration should take (faster = suspicious)
MIN_REGISTRATION_SECONDS=4

# --- Geolocation ---
# Free IP geolocation API — no key needed for HTTP
GEO_API_URL=http://ip-api.com/json
# For local dev, requests from 127.0.0.1 will be mocked with this country
GEO_LOCAL_MOCK_COUNTRY=India

# --- ML Model ---
# Path to the saved Isolation Forest model
ML_MODEL_PATH=./ml_model.pkl
# Contamination rate used when training (expected fraction of anomalies)
ML_CONTAMINATION=0.1

# --- Admin ---
# Credentials for the first admin account (seeded on first run)
ADMIN_EMAIL=admin@sentinelai.dev
ADMIN_PASSWORD=changeme_before_demo

# --- CORS ---
# Frontend URL — update if running on a different port
FRONTEND_URL=http://localhost:5173

# --- Demo / Scripts ---
# The base URL scripts use to hit the API
API_BASE_URL=http://localhost:8000/api
