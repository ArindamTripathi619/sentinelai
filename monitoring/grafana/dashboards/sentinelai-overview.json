{
  "uid": "sentinelai-overview",
  "title": "SentinelAI Overview",
  "tags": ["sentinelai", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "API Request Rate (RPS)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(sentinelai_api_requests_total[1m]))",
          "legendFormat": "Total RPS"
        }
      ]
    },
    {
      "id": 5,
      "title": "RPS by Endpoint",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(5, sum(rate(sentinelai_api_requests_total[1m])) by (endpoint))",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Error Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(sentinelai_api_errors_total[1m])) / sum(rate(sentinelai_api_requests_total[1m]))",
          "legendFormat": "Error %"
        }
      ]
    },
    {
      "id": 2,
      "title": "API Latency (p95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(sentinelai_api_request_duration_seconds_bucket[1m])) by (le, endpoint)) * 1000",
          "legendFormat": "{{endpoint}} p95"
        }
      ]
    },
    {
      "id": 3,
      "title": "API Latency (p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum(rate(sentinelai_api_request_duration_seconds_bucket[1m])) by (le, endpoint)) * 1000",
          "legendFormat": "{{endpoint}} p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "Request Distribution by Status Code",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(sentinelai_api_requests_total[5m])) by (status_code)",
          "legendFormat": "{{status_code}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Login Attempts",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(sentinelai_auth_login_total[1m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Security Rules Triggered",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(sentinelai_security_rules_triggered_total[5m])) by (rule_name)",
          "legendFormat": "{{rule_name}}"
        }
      ]
    }
  ]
}
